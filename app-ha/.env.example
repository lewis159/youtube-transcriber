# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://ygfxzkpkwyqqvibljxpw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── AI provider (summaries + Q&A chat) ────────────────────────────────────────
# AI summaries (ai_summary flag) and the Q&A chat (summary_chat flag) run through
# a pluggable provider. The DEFAULT is your OWN local LLM (Ollama / Open WebUI)
# via its OpenAI-compatible API — this needs NO Anthropic key.
#
# LLM_PROVIDER: 'local' (default) or 'anthropic'.
LLM_PROVIDER=local
#
# Local provider (LLM_PROVIDER=local) — point at your OpenAI-compatible endpoint:
#   Ollama:      http://your-host:11434/v1
#   Open WebUI:  https://your-openwebui-host/api   (its OpenAI-compatible base)
LLM_BASE_URL=http://localhost:11434/v1
# The local model name to use (e.g. llama3.2, qwen2.5).
LLM_MODEL=llama3.2
# Optional bearer token — required by Open WebUI, omit for a bare Ollama box.
LLM_API_KEY=

# Claude / Anthropic API — ONLY needed when LLM_PROVIDER=anthropic.
# With the default LLM_PROVIDER=local you can leave this unset.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
